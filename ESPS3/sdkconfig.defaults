# ESP32-S3 N32R16 local gateway defaults.
CONFIG_S3_LOCAL_LD2450_UART_ENABLED=y
CONFIG_S3_LOCAL_LD2450_UART_PORT=1
CONFIG_S3_LOCAL_LD2450_UART_TX_GPIO=18
CONFIG_S3_LOCAL_LD2450_UART_RX_GPIO=17

CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
CONFIG_PARTITION_TABLE_OFFSET=0x8000

CONFIG_ESPTOOLPY_FLASHSIZE_32MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="32MB"

CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_TYPE_AUTO=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_BOOT_INIT=y
CONFIG_SPIRAM_USE_MALLOC=y
CONFIG_SPIRAM_MEMTEST=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=16384
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=32768
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_FREERTOS_TASK_CREATE_ALLOW_EXT_MEM=y

CONFIG_ESP_MAIN_TASK_STACK_SIZE=8192
# Comprehensive poisoning verifies every free region, including the 16 MiB
# PSRAM heap.  The default 300 ms IWDT window is shorter than that startup scan.
CONFIG_ESP_INT_WDT_TIMEOUT_MS=5000
# FreeRTOS method 2 canaries plus comprehensive heap poisoning are required
# for startup memory-corruption diagnosis.
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_CANARY=y
CONFIG_HEAP_POISONING_COMPREHENSIVE=y
CONFIG_COMPILER_STACK_CHECK_MODE_ALL=y
CONFIG_HTTPD_MAX_REQ_HDR_LEN=1024
CONFIG_HTTPD_MAX_URI_LEN=256
CONFIG_MBEDTLS_SSL_IN_CONTENT_LEN=16384
CONFIG_MBEDTLS_SSL_OUT_CONTENT_LEN=16384
# CONFIG_WS_TRANSPORT is not set
# SPI flash auto-suspend is disabled; forcing generic system code into the
# constrained bootloader IRAM gives no cache-off benefit and overflows it.
# CONFIG_ESP_SYSTEM_IN_IRAM is not set
